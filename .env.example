# Agentic Red-Team Manager Configuration

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Database Configuration
DATABASE_URL=postgresql://redteam:redteam123@localhost:5432/redteam
REDIS_URL=redis://localhost:6379/0

# AI/ML API Keys (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
HUGGINGFACE_API_TOKEN=your-huggingface-token-here

# Security Configuration
SECRET_KEY=your-secret-key-here-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Sandbox Configuration
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_TIMEOUT=300
SANDBOX_MEMORY_LIMIT=1GB
SANDBOX_NETWORK_ISOLATION=true

# Safety Configuration
MAX_RISK_LEVEL=medium
AUTO_INTERVENTION=true
SAFETY_THRESHOLD=30

# Report Configuration
REPORTS_DIR=./reports
REPORT_FORMATS=html,json,pdf

# Monitoring Configuration
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
METRICS_PORT=9000

# Logging Configuration
LOG_FORMAT=json
LOG_FILE=./logs/redteam.log
LOG_ROTATION=daily

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@agenticredteam.com

# Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# Development Configuration
RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080